<Ui xmlns="http://www.blizzard.com/wow/ui/"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.blizzard.com/wow/ui/ ..\FrameXML\UI.xsd">

    <!--
        BitForgeButtonTemplate
        MD contained button (filled, Indigo 500 primary colour).
        Textures are solid white and tinted via LibBitForgeUI.ButtonMixin:OnLoad().
        HighlightTexture uses ADD blend for a lighter overlay on hover.

        Usage:
            CreateFrame("Button", "MyButton", UIParent, "BitForgeButtonTemplate")
    -->
    <Button name="BitForgeButtonTemplate" virtual="true">

        <Size x="120" y="36" />

        <!-- Normal: Indigo 500 tint applied in OnLoad -->
        <NormalTexture parentKey="NormalTex" file="Interface\Buttons\WHITE8X8">
            <Anchors>
                <Anchor point="TOPLEFT" />
                <Anchor point="BOTTOMRIGHT" />
            </Anchors>
        </NormalTexture>

        <!-- Highlight: lighter Indigo overlay (ADD blend) -->
        <HighlightTexture parentKey="HighlightTex" file="Interface\Buttons\WHITE8X8" alphaMode="ADD">
            <Anchors>
                <Anchor point="TOPLEFT" />
                <Anchor point="BOTTOMRIGHT" />
            </Anchors>
        </HighlightTexture>

        <!-- Pushed: Indigo 700 tint applied in OnLoad -->
        <PushedTexture parentKey="PushedTex" file="Interface\Buttons\WHITE8X8">
            <Anchors>
                <Anchor point="TOPLEFT" />
                <Anchor point="BOTTOMRIGHT" />
            </Anchors>
        </PushedTexture>

        <!-- Disabled: grey tint applied in OnLoad -->
        <DisabledTexture parentKey="DisabledTex" file="Interface\Buttons\WHITE8X8">
            <Anchors>
                <Anchor point="TOPLEFT" />
                <Anchor point="BOTTOMRIGHT" />
            </Anchors>
        </DisabledTexture>

        <!-- Button label — white, centred -->
        <ButtonText parentKey="Text" inherits="GameFontNormal"
            text="" justifyH="CENTER" justifyV="MIDDLE">
            <Anchors>
                <Anchor point="CENTER" />
            </Anchors>
            <Color r="1" g="1" b="1" a="1" />
        </ButtonText>

    </Button>

    <!--
        BitForgeScrollElementAsButtonTemplate
        Boilerplate virtual Button for use as a ScrollBox element.
        Provides a highlight texture and a default label.
        Override Init(data) via a second Mixin to populate the element.

        Usage:
            local factory = CreateScrollBoxListElementFactory(
                "BitForgeScrollElementAsButtonTemplate",
                function(frame, data) frame:Init(data) end
            )
            ScrollUtil.InitScrollBoxListWithScrollBar(scrollBox, scrollBar, dataProvider, factory,
    elementExtent)
    -->
    <Button name="BitForgeScrollElementAsButtonTemplate" virtual="true">

        <Size x="200" y="32" />

        <!-- Highlight overlay (ADD blend); tint applied in OnLoad -->
        <HighlightTexture parentKey="HighlightTex" file="Interface\Buttons\WHITE8X8" alphaMode="ADD">
            <Anchors>
                <Anchor point="TOPLEFT" />
                <Anchor point="BOTTOMRIGHT" />
            </Anchors>
        </HighlightTexture>

        <!-- Default label; set text via Init(data) or replace with your own layout -->
        <ButtonText parentKey="Label" inherits="GameFontNormal"
            text="" justifyH="LEFT" justifyV="MIDDLE">
            <Anchors>
                <Anchor point="LEFT" x="8" y="0" />
                <Anchor point="RIGHT" x="-8" y="0" />
            </Anchors>
            <Color r="1" g="1" b="1" a="1" />
        </ButtonText>

    </Button>

    <!--
        BitForgeScrollElementAsCheckTemplate
        Boilerplate virtual CheckButton for use as a ScrollBox element.
        Provides a checkbox background, checked, and highlight texture, plus a default label.
        Override Init(data) via a second Mixin to populate the element.

        Usage:
            local factory = CreateScrollBoxListElementFactory(
                "BitForgeScrollElementAsCheckTemplate",
                function(frame, data) frame:Init(data) end
            )
            ScrollUtil.InitScrollBoxListWithScrollBar(scrollBox, scrollBar, dataProvider, factory,
    elementExtent)
    -->
    <CheckButton name="BitForgeScrollElementAsCheckTemplate" virtual="true">

        <Size x="200" y="32" />

        <!-- Background square; always visible, tinted Colors.disabled in OnLoad -->
        <NormalTexture parentKey="NormalTex" file="Interface\Buttons\WHITE8X8">
            <Anchors>
                <Anchor point="TOPLEFT" />
                <Anchor point="BOTTOMRIGHT" />
            </Anchors>
        </NormalTexture>

        <!-- Checked overlay; tinted Colors.primary in OnLoad -->
        <CheckedTexture parentKey="CheckedTex" file="Interface\Buttons\WHITE8X8">
            <Anchors>
                <Anchor point="TOPLEFT" />
                <Anchor point="BOTTOMRIGHT" />
            </Anchors>
        </CheckedTexture>

        <!-- Highlight overlay (ADD blend); tint applied in OnLoad -->
        <HighlightTexture parentKey="HighlightTex" file="Interface\Buttons\WHITE8X8" alphaMode="ADD">
            <Anchors>
                <Anchor point="TOPLEFT" />
                <Anchor point="BOTTOMRIGHT" />
            </Anchors>
        </HighlightTexture>

        <!-- Default label; set text via Init(data) or replace with your own layout -->
        <ButtonText parentKey="Label" inherits="GameFontNormal"
            text="" justifyH="LEFT" justifyV="MIDDLE">
            <Anchors>
                <Anchor point="LEFT" x="8" y="0" />
                <Anchor point="RIGHT" x="-8" y="0" />
            </Anchors>
            <Color r="1" g="1" b="1" a="1" />
        </ButtonText>

    </CheckButton>

    <!--
        BitForgeCheckboxTemplate
        MD-style checkbox. NormalTexture is tinted Colors.disabled (background square);
        CheckedTexture is tinted Colors.primary and shown/hidden natively by CheckButton.
        Customise colours globally via LibBitForgeUI:SetPalette().

        Usage:
            CreateFrame("CheckButton", "MyCheck", UIParent, "BitForgeCheckboxTemplate")
    -->
    <CheckButton name="BitForgeCheckboxTemplate" virtual="true">

        <Size x="20" y="20" />

        <!-- Background square; always visible, tinted Colors.disabled in OnLoad -->
        <!-- TODO: replace file path with custom tick-mark texture when assets are ready -->
        <NormalTexture parentKey="NormalTex"
            file="Interface\Buttons\WHITE8X8">
            <Anchors>
                <Anchor point="TOPLEFT" />
                <Anchor point="BOTTOMRIGHT" />
            </Anchors>
        </NormalTexture>

        <!-- TODO: replace file path with custom tick-mark texture when assets are ready -->
        <CheckedTexture parentKey="CheckedTex"
            file="Interface\Buttons\WHITE8X8">
            <Anchors>
                <Anchor point="TOPLEFT" />
                <Anchor point="BOTTOMRIGHT" />
            </Anchors>
        </CheckedTexture>

        <!-- Hover overlay (ADD blend) -->
        <HighlightTexture parentKey="HighlightTex"
            file="Interface\Buttons\WHITE8X8"
            alphaMode="ADD">
            <Anchors>
                <Anchor point="TOPLEFT" />
                <Anchor point="BOTTOMRIGHT" />
            </Anchors>
        </HighlightTexture>

        <!-- Inline label; anchored to the right of the checkbox -->
        <ButtonText parentKey="Label" inherits="GameFontNormal"
            text="" justifyH="LEFT" justifyV="MIDDLE">
            <Anchors>
                <Anchor point="LEFT" relativeTo="$parent" relativePoint="RIGHT" x="6" y="0" />
            </Anchors>
            <Color r="1" g="1" b="1" a="1" />
        </ButtonText>

    </CheckButton>

</Ui>