<Ui xmlns="http://www.blizzard.com/wow/ui/"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.blizzard.com/wow/ui/ ..\FrameXML\UI.xsd">

    <!--
        BitForgeTabButtonTemplate
        MD-style tab button.

        Visual states
        ─────────────
        Default   : no visible decoration
        Hover     : 2px indicator line on the outer edge (Colors.primaryHover)
        Selected  : Colors.bg fill + Colors.primary indicator + side borders;
                    the content-adjacent edge is left open for a seamless look

        The "outer edge" and which border pair is omitted depend on tab position,
        which is set via TabButtonMixin:SetTabPosition(pos).

        Usage
        ─────
        Usually managed by BitForgeTabBarTemplate; for standalone use:
            local btn = CreateFrame("CheckButton", nil, parent, "BitForgeTabButtonTemplate")
            btn:SetSize(80, 32)
            btn:SetText("General")
            btn:SetTabPosition("bottom")   (pos: "top" | "left" | "right")
    -->
    <CheckButton name="BitForgeTabButtonTemplate" virtual="true">

        <Size x="80" y="32" />

        <Layers>

            <!-- Background fill: shown (Colors.bg) when selected, hidden otherwise -->
            <Layer level="BACKGROUND">
                <Texture parentKey="Bg" file="Interface\Buttons\WHITE8X8" hidden="true">
                    <Anchors>
                        <Anchor point="TOPLEFT" />
                        <Anchor point="BOTTOMRIGHT" />
                    </Anchors>
                </Texture>
            </Layer>

            <!-- 1px border strips — anchors re-set by Lua; shown/hidden per state -->
            <Layer level="ARTWORK">
                <Texture parentKey="BorderTop" file="Interface\Buttons\WHITE8X8" hidden="true">
                    <Size y="1" />
                </Texture>
                <Texture parentKey="BorderBottom" file="Interface\Buttons\WHITE8X8" hidden="true">
                    <Size y="1" />
                </Texture>
                <Texture parentKey="BorderLeft" file="Interface\Buttons\WHITE8X8" hidden="true">
                    <Size x="1" />
                </Texture>
                <Texture parentKey="BorderRight" file="Interface\Buttons\WHITE8X8" hidden="true">
                    <Size x="1" />
                </Texture>
            </Layer>

            <!-- 2px indicator line — anchors re-set by Lua based on position -->
            <Layer level="OVERLAY">
                <Texture parentKey="Indicator" file="Interface\Buttons\WHITE8X8" hidden="true">
                    <Size y="2" />
                </Texture>
            </Layer>

            <!-- Label -->
            <Layer level="OVERLAY">
                <FontString parentKey="Label" inherits="GameFontNormal"
                    text="" justifyH="CENTER" justifyV="MIDDLE">
                    <Anchors>
                        <Anchor point="TOPLEFT" x="4" y="-4" />
                        <Anchor point="BOTTOMRIGHT" x="-4" y="4" />
                    </Anchors>
                    <Color r="1" g="1" b="1" a="1" />
                </FontString>
            </Layer>

        </Layers>

    </CheckButton>

    <!--
        BitForgeTabBarTemplate
        Container for a set of tab buttons.

        Usage
        ─────
            local bar = CreateFrame("Frame", nil, UIParent, "BitForgeTabBarTemplate")
            bar:SetSize(320, 32)
            bar:SetPoint("BOTTOMLEFT", contentFrame, "TOPLEFT")   (tabs above content)
            bar:SetPosition("top")                                 (indicator on top edge)

            bar:AddTab(1, "General")
            bar:AddTab(2, "Advanced")
            bar:SetSelectedTab(1)
            bar:SetOnChange(function(id) print("selected:", id) end)
    -->
    <Frame name="BitForgeTabBarTemplate" virtual="true">

        <Size x="320" y="32" />

    </Frame>

</Ui>