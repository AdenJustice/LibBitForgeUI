<Ui xmlns="http://www.blizzard.com/wow/ui/"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.blizzard.com/wow/ui/ ..\FrameXML\UI.xsd">

    <!--
        BitForgeDropdownTemplate
        MD-style single-select dropdown.
        Backdrop and colours applied in LibBitForgeUI.DropdownMixin:OnLoad().
        Item rows are created dynamically by SetItems().

        Usage:
            local dd = CreateFrame("Frame", "MyDD", UIParent, "BitForgeDropdownTemplate")
            dd:SetItems({ { value = 1, label = "Option A" }, { value = 2, label = "Option B" } })
            dd:SetPlaceholder("Pick one…")
            dd:SetOnChange(function(v) print(v) end)
    -->
    <Frame name="BitForgeDropdownTemplate" virtual="true" enableMouse="false">

        <Size x="200" y="32" />

        <Frames>

            <!-- Header: the visible bar the user clicks to open / close the list.
                 Backdrop and OnClick script are wired in OnLoad. -->
            <Button parentKey="Header" inherits="BackdropTemplate">
                <Anchors>
                    <Anchor point="TOPLEFT" />
                    <Anchor point="BOTTOMRIGHT" />
                </Anchors>
                <Layers>
                    <Layer level="OVERLAY">
                        <!-- Selected value or placeholder -->
                        <FontString parentKey="Text" inherits="GameFontNormal"
                            justifyH="LEFT" justifyV="MIDDLE" text="">
                            <Anchors>
                                <Anchor point="LEFT" relativePoint="LEFT" x="8" y="0" />
                                <Anchor point="RIGHT" relativePoint="RIGHT" x="-24" y="0" />
                            </Anchors>
                        </FontString>
                        <!-- Chevron ▾ / ▴ toggled in _Toggle() -->
                        <FontString parentKey="Chevron" inherits="GameFontNormal"
                            justifyH="RIGHT" justifyV="MIDDLE" text="▾">
                            <Anchors>
                                <Anchor point="RIGHT" relativePoint="RIGHT" x="-8" y="0" />
                            </Anchors>
                            <Color r="1" g="1" b="1" a="1" />
                        </FontString>
                    </Layer>
                </Layers>
            </Button>

            <!-- Popup list: shown/hidden by _Toggle(); sized and populated by SetItems(). -->
            <Frame parentKey="List" hidden="true" frameStrata="DIALOG"
                inherits="BackdropTemplate">
                <Anchors>
                    <!-- Anchors to the outer BitForgeDropdownTemplate frame -->
                    <Anchor point="TOPLEFT" relativePoint="BOTTOMLEFT" x="0" y="-2" />
                </Anchors>
                <!-- Size overridden by SetItems() in Lua -->
                <Size x="200" y="4" />
            </Frame>

        </Frames>

    </Frame>

</Ui>