<Ui xmlns="http://www.blizzard.com/wow/ui/"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.blizzard.com/wow/ui/ ..\FrameXML\UI.xsd">

    <!--
        BitForgeFrameTemplate
        MD card-style movable frame, no title bar.
        Provides backdrop, bottom-edge shadow, and drag/show/hide hooks.

        Usage:
            CreateFrame("Frame", "MyFrame", UIParent, "BitForgeFrameTemplate")
    -->
    <Frame name="BitForgeFrameTemplate" virtual="true" movable="true" enableMouse="true"
        clampedToScreen="true" inherits="BackdropTemplate">
        <Size x="300" y="200" />

        <Layers>
            <!-- Elevation shadow strip along the bottom edge (MD 2dp) -->
            <Layer level="BACKGROUND">
                <Texture parentKey="Shadow"
                    file="Interface\Tooltips\UI-Tooltip-Background"
                    hidden="false" alpha="0.4">
                    <Size y="4" />
                    <Anchors>
                        <Anchor point="BOTTOMLEFT" relativePoint="BOTTOMLEFT" x=" 2" y="-2" />
                        <Anchor point="BOTTOMRIGHT" relativePoint="BOTTOMRIGHT" x="-2" y="-2" />
                    </Anchors>
                    <Color r="0" g="0" b="0" a="0.6" />
                </Texture>
            </Layer>
        </Layers>

    </Frame>

    <!--
        BitForgeFrameWithTitleTemplate
        Extends BitForgeFrameTemplate with an Indigo 500 title bar and a label.

        Usage:
            CreateFrame("Frame", "MyFrame", UIParent, "BitForgeFrameWithTitleTemplate")
    -->
    <Frame name="BitForgeFrameWithTitleTemplate" virtual="true"
        inherits="BitForgeFrameTemplate">

        <Layers>
            <!-- Title bar background (MD Indigo 500) -->
            <Layer level="BACKGROUND">
                <Texture parentKey="TitleBar"
                    file="Interface\Buttons\WHITE8X8">
                    <Size y="32" />
                    <Anchors>
                        <Anchor point="TOPLEFT" relativePoint="TOPLEFT" x="0" y="0" />
                        <Anchor point="TOPRIGHT" relativePoint="TOPRIGHT" x="0" y="0" />
                    </Anchors>
                    <Color r="0.251" g="0.318" b="0.710" a="1" />
                </Texture>
            </Layer>

            <!-- Title bar label -->
            <Layer level="OVERLAY">
                <FontString parentKey="Title" inherits="GameFontNormal"
                    text="" justifyH="CENTER" justifyV="MIDDLE">
                    <Size y="32" />
                    <Anchors>
                        <Anchor point="TOPLEFT" relativePoint="TOPLEFT" x="12" y="0" />
                        <Anchor point="TOPRIGHT" relativePoint="TOPRIGHT" x="-12" y="0" />
                    </Anchors>
                    <Color r="1" g="1" b="1" a="1" />
                </FontString>
            </Layer>
        </Layers>

    </Frame>

</Ui>