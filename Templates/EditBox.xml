<Ui xmlns="http://www.blizzard.com/wow/ui/"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.blizzard.com/wow/ui/ ..\FrameXML\UI.xsd">

    <!--
        BitForgeEditBoxTemplate
        MD outlined text field.
        Background and border are tinted via LibBitForgeUI.EditBoxMixin:OnLoad().
        Border colour switches to Indigo 500 on focus.

        Usage:
            CreateFrame("EditBox", "MyEditBox", UIParent, "BitForgeEditBoxTemplate")
    -->
    <EditBox name="BitForgeEditBoxTemplate" virtual="true"
        autoFocus="false" inherits="BackdropTemplate">

        <Size x="200" y="32" />

        <!-- Text padding inside the box -->
        <TextInsets>
            <AbsInset left="8" right="8" top="0" bottom="0" />
        </TextInsets>

    </EditBox>

    <!--
        BitForgeMultiLineEditBoxTemplate
        MD outlined multi-line text field.
        The inner EditBox and its scroll wiring are created in
        MultiLineEditBoxMixin:OnLoad(); consumers interact via self.EditBox.

        Usage:
            CreateFrame("Frame", "MyBox", UIParent, "BitForgeMultiLineEditBoxTemplate")
            MyBox.EditBox:SetText("Hello")
    -->
    <Frame name="BitForgeMultiLineEditBoxTemplate" virtual="true" inherits="BackdropTemplate">

        <Size x="200" y="120" />

        <Frames>
            <!-- ScrollFrame provides scroll bar; EditBox is attached in Lua OnLoad -->
            <ScrollFrame parentKey="ScrollFrame" inherits="UIPanelScrollFrameTemplate">
                <Anchors>
                    <Anchor point="TOPLEFT" relativePoint="TOPLEFT" x="4" y="-4" />
                    <Anchor point="BOTTOMRIGHT" relativePoint="BOTTOMRIGHT" x="-20" y="4" />
                </Anchors>
            </ScrollFrame>
        </Frames>

    </Frame>

</Ui>